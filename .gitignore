# Dependencies - these folders contain thousands of files that can be
# regenerated by running "npm install". Never commit these.
node_modules/

# Environment files - these contain passwords, API keys, secrets.
# NEVER commit these. Each developer creates their own .env locally.
.env
.env.local
.env.production

# Build output - generated files, not source code
dist/
build/

# Log files - runtime logs, not part of the codebase
logs/
*.log
npm-debug.log*

# OS-generated files - your operating system creates these, not you
.DS_Store
Thumbs.db

# IDE/Editor files - your editor's personal config
.vscode/
.idea/

# Test coverage reports - generated when you run tests with coverage
coverage/

smart_hostel_data/

commits_with_patches.txt
commits.txt
commits_with_stats.txt
intelli_tree.txt
team_execution.md